<mjml>
  <mj-head>
    <mj-include path="_style.mjml"/>
    <mj-preview>
      Your FAF password was changed
    </mj-preview>
  </mj-head>
  <mj-body background-color="#fafafa">
    <mj-include path="_header.mjml"/>

    <mj-section background-color="#ffffff">
      <mj-column>
        <mj-text>
          <h1>Your password was changed</h1>
          <p>Dear {{username}},</p>
          <p>
            The password on your FAForever account was just successfully changed.
          </p>
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section background-color="gray" padding="0">
      <mj-column>
        <mj-text color="#d3d3d3">
          <p>
            If you did not request this change, please contact us immediately at admin@faforever.com.
          </p>
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-include path="_footer.mjml"/>
  </mj-body>
</mjml>